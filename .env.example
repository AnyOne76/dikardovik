# БД (SQLite). На сервере укажите путь к файлу вне публичной директории, права на запись.
# Пример продакшена: file:/var/www/kadrovik/data/prod.db
DATABASE_URL="file:./prisma/dev.db"

# Сгенерируйте длинную случайную строку (например: openssl rand -base64 32)
NEXTAUTH_SECRET="replace_with_long_random_secret"

# Продакшен / Docker / LAN: точный URL из браузера с портом (пример Docker: http://localhost:25531, LAN: http://10.0.5.173:25531).
# Локально без Docker (npm run dev): http://localhost:3000
NEXTAUTH_URL="http://localhost:25531"

# NextAuth: доверять заголовку Host (в Docker Compose уже включено). Устраняет ошибки входа (в т.ч. 400),
# если публичный URL — с проброшенным портом или отличается от localhost внутри контейнера.
# AUTH_TRUST_HOST=true

# Открывайте приложение тем же хостом, что в NEXTAUTH_URL (не смешивайте localhost и 127.0.0.1).
# Заход по LAN (например http://10.0.5.173:25531) — задайте NEXTAUTH_URL с этим хостом и портом.

# Регистрация по приглашению: тот же код, что отправляете выбранным пользователям по почте.
# Без значения регистрация через API отключена.
REGISTRATION_INVITE_CODE=""

# Первый администратор (скрипт seed). На проде смените пароль после первого входа.
SEED_ADMIN_LOGIN="hr-admin"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# Ключи API ниже необязательны, если админ задал их в разделе «Настройки API» (/admin/settings) — значения из БД имеют приоритет над .env.
PERPLEXITY_API_KEY=""
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"
# Вторая модель для сверки извлечённого JSON с исходником (анти-галлюцинации). Пусто = тот же OPENROUTER_MODEL.
OPENROUTER_VERIFY_MODEL=""
# 1 / true — отключить второй проход проверки (только отладка).
OPENROUTER_VERIFY_DISABLED=""
PERPLEXITY_MODEL="sonar-pro"
# 1 — отключить третий проход (LLM-редактор): остаются нормализация + Яндекс.Спеллер (быстрее и без повторного запроса к OpenRouter).
DI_TEXT_QUALITY_FAST=""
