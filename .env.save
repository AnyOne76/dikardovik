# БД (SQLite). На сервере укажите путь к файлу вне публичной директории, права на запись.
# Пример продакшена: file:/var/www/kadrovik/data/prod.db
DATABASE_URL="file:./prisma/dev.db"

# Сгенерируйте длинную случайную строку (например: openssl rand -base64 32)
NEXTAUTH_SECRET="replace_with_long_random_secret"

# Локально: http://localhost:3000 (если приложение на другом порту — укажите его, например http://localhost:25531)
# Продакшен: полный URL сайта с протоколом, например https://kadrovik.example.ru
# В Docker Compose по умолчанию: http://localhost:25531 (см. docker-compose.yml)
NEXTAUTH_URL="http://localhost:25531"

# Регистрация по приглашению: тот же код, что отправляете выбранным пользователям по почте.
# Без значения регистрация через API отключена.
REGISTRATION_INVITE_CODE="SUPER_SECRET_INVITE_CODEmr123!@#5_"

# Первый администратор (скрипт seed). На проде смените пароль после первого входа.
SEED_ADMIN_LOGIN="hr-admin"
SEED_ADMIN_PASSWORD="ChangeMe123!"
==
PERPLEXITY_API_KEY=""
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"
PERPLEXITY_MODEL="sonar-pro"
